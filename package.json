    "rcon-client": "^4.2.5",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.1.18",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@buf/minekube_gate.connectrpc_es": "1.6.1-20250516132630-2a0c7768e191.2",
