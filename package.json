    "@bufbuild/protobuf": "^1.0.0",
    "@connectrpc/connect-node": "^1.6.1",
    "@kubernetes/client-node": "^1.4.0",
    "@tailwindcss/cli": "^4.1.18",
    "@types/bun": "latest",
