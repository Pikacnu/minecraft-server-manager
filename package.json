{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts",
    "cluster:create": "kind create cluster --config kind-config.yaml",
    "cluster:delete": "kind delete cluster --name minecraft-dev"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.561.0",
    "rcon-client": "^4.2.5",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@buf/minekube_gate.connectrpc_es": "1.6.1-20250516132630-2a0c7768e191.2",
    "@bufbuild/buf": "1.47.2",
    "@bufbuild/connect": "^0.13.0",
    "@bufbuild/protobuf": "^1.0.0",
    "@connectrpc/connect-node": "^1.6.1",
    "@kubernetes/client-node": "^1.4.0",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-plugin-auto-imports": "^0.3.1",
    "bun-plugin-tailwind": "^0.1.2"
  }
}