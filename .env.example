# Environment configuration for Minecraft Server Manager

# Application environment
NODE_ENV=development

# Namespace and application name
NAMESPACE=minecraft-servers
APP_NAME=minecraft-server-manager

# Velocity secret
VELOCITY_SECRET=my-secret-123

# RCON password
RCON_PASSWORD=rconpassword

# NFS server configuration
NFS_SERVER=nfs-server.local
NFS_PATH=

# Cloudflare API token
CLOUDFLARE_API_TOKEN=

# Domain name and proxy IP
DOMAIN_NAME=
PROXY_IP=

# SRV port
SRVPORT=25565

# Cloudflare Zone ID
ZONE_ID=

# Wildcard domain configuration
WILDCARD_DOMAIN_PREFIX=srv-mc-only
USE_WILDCARD_DOMAIN=true